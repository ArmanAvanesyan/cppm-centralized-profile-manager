# Line endings: normalize to LF in repo, checkout as-is on Windows
* text=auto eol=lf
*.{cmd,bat} text eol=crlf

# Binary and generated files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary

# Diff / merge
*.md text diff=markdown
*.py text diff=python
*.dart text diff=dart
*.yaml text
*.yml text
*.json text
*.toml text
*.lock binary
