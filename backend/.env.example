# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cppm

# JWT
JWT_SECRET=your-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP (email auth)
OTP_SECRET=your-otp-secret
OTP_EXPIRE_MINUTES=10

# Google OAuth (auth + Google Drive)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Dropbox OAuth (cloud storage)
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# LinkedIn OAuth (Sign in with LinkedIn)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Cloud storage callback base URL (no trailing slash)
STORAGE_CALLBACK_BASE_URL=http://localhost:8000/api/v1/storage/callback
