# Git and version control
.git
.gitignore
.gitattributes

# IDE and editor
.idea
.vscode
.cursor
*.iml

# OS
.DS_Store
Thumbs.db

# Python backend (if image builds backend only: keep source, ignore venv/cache)
backend/.venv
backend/venv
backend/__pycache__
backend/.pytest_cache
backend/.ruff_cache
backend/.mypy_cache
backend/htmlcov
backend/.coverage
*.pyc
*.pyo

# Flutter frontend (exclude build artifacts and tooling from context)
frontend/app/.dart_tool
frontend/app/build
frontend/app/.packages
frontend/app/ios/Pods
frontend/app/ios/.symlinks
frontend/app/ios/Flutter/Flutter.framework
frontend/app/android/.gradle
frontend/app/android/local.properties
frontend/app/windows/flutter/ephemeral
frontend/app/macos/Flutter/ephemeral
frontend/packages/design_system/.dart_tool
frontend/packages/design_system/build

# Docs (include only if image needs them; remove this line to include docs)
# docs

# Env and secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets

# Misc
*.log
*.tmp
.cache
